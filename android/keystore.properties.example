# Template for android/keystore.properties (NOT committed — see .gitignore)
# Copy this to android/keystore.properties and fill in real values before
# building a signed release AAB.
#
# Generate the keystore once:
#   keytool -genkey -v -keystore trado-release.jks -keyalg RSA -keysize 2048 \
#           -validity 10000 -alias trado
#
# Store the .jks file at android/app/trado-release.jks (also gitignored).
# Back up the .jks AND these passwords somewhere safe — losing them means
# you can never update the app on Play Store.

storeFile=trado-release.jks
storePassword=YOUR_STORE_PASSWORD
keyAlias=trado
keyPassword=YOUR_KEY_PASSWORD
